# Sony SED-E1 connection config
# Copy to glasses.conf and edit.

# bt_address: MAC of your glasses, or "auto" to scan at startup
bt_address=auto
# bt_address=ac:9b:0a:37:a6:c6   # pin to a specific pair

rfcomm_channel=4
capture_log=/tmp/glasses_capture.log

# WiFi credentials (also readable from .env SSID= / PSWD=)
# wifi_ssid=MyNetwork
# wifi_pswd=MyPassword
