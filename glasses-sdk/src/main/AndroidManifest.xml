<?xml version="1.0" encoding="utf-8"?>
<!--
    glasses-sdk AndroidManifest
    
    ALL Sony permissions are declared here so apps using the SDK
    don't need to know they exist.
    
    Apps using the SDK need only:
      1. Add implementation 'dev.glasses:glasses-sdk:1.0.0' to their build.gradle
      2. Call Glasses.get(context) - that's it
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="dev.glasses">

    <!-- Sony permissions: SDK holds these, not the calling app -->
    <uses-permission android:name="com.sony.smarteyeglass.permission.SMARTEYEGLASS" />
    <uses-permission android:name="com.sonyericsson.extras.liveware.aef.EXTENSION_PERMISSION" />

    <!-- Standard permissions needed for sensors/camera features -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application>

        <!--
            GlassesBridgeService: handles all Smart Connect registration,
            routing and lifecycle. Auto-started on first Glasses.get() call.
        -->
        <service
            android:name="dev.glasses.GlassesBridgeService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.sonyericsson.extras.liveware.aef.EXTENSION" />
            </intent-filter>
        </service>

        <!--
            RegistrationReceiver: wakes up GlassesBridgeService when
            Smart Connect requests registration. Auto-triggered.
        -->
        <receiver
            android:name="dev.glasses.RegistrationReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.sonyericsson.extras.liveware.aef.registration.EXTENSION_REGISTER_REQUEST" />
                <action android:name="com.sonyericsson.extras.liveware.aef.registration.CAPABILITY_CHANGED" />
                <action android:name="com.sonyericsson.extras.liveware.aef.registration.ACCESSORY_CONNECTION" />
            </intent-filter>
        </receiver>

        <!-- Unique extension key for this SDK instance -->
        <meta-data
            android:name="com.sonyericsson.extras.liveware.aef.registration.EXTENSION_KEY"
            android:value="dev.glasses.sdk.key" />

    </application>

</manifest>
